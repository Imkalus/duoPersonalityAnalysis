# ===== LLM 配置（OpenAI 兼容接口）=====
# API 基础地址，结尾不要带 /chat/completions
LLM_BASE_URL=https://api.openai.com/v1
# 你的 API Key
LLM_API_KEY=your-api-key-here
# 模型名称，例如 gpt-4o-mini / mimo-v2.5
LLM_MODEL=gpt-4o-mini

# ===== 服务端配置 =====
# 监听端口（默认 3000）
PORT=3000
# 监听地址（默认 0.0.0.0，云服务器需保持，本机调试可用 127.0.0.1）
HOST=0.0.0.0
# 允许的跨域来源（默认 * 全部允许；生产建议填你的域名，如 https://your-domain.com）
CORS_ORIGIN=*
# 前端构建产物目录（默认 ../client/dist，单进程部署时由后端托管前端）
# CLIENT_DIST=/path/to/client/dist
