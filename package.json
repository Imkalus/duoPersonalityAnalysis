{
  "name": "mbti-duo",
  "version": "0.1.0",
  "private": true,
  "description": "MBTI 双人测试 Web 应用",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --filter @mbti-duo/server dev\" \"bun run --filter @mbti-duo/client dev\"",
    "dev:server": "bun run --filter @mbti-duo/server dev",
    "dev:client": "bun run --filter @mbti-duo/client dev",
    "build": "bun run --filter @mbti-duo/server build && bun run --filter @mbti-duo/client build",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
